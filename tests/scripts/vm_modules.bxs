// Integration test: verify module BIFs, class imports, and settings via bxModules prefix

import bxModules.greetings.models.Greeter as Greeter;

// 1. BIF provided by the module (injected as extra prelude)
msg = greetUser("World")
if (msg != "Hello, World!") {
    throw "greetUser BIF returned unexpected value: " & msg
}

// 2. Class imported from the module via bxModules path
g = new Greeter()
g.init("Matchbox")
result = g.getMessage()
if (result != "Greetings from Matchbox!") {
    throw "Greeter.getMessage() returned unexpected value: " & result
}

// 3. Settings populated by ModuleConfig.bx configure() lifecycle
config = getModuleSettings("greetings")
if (config.language != "en") {
    throw "Expected config.language 'en', got: " & config.language
}
if (config.enthusiastic != false) {
    throw "Expected config.enthusiastic false, got: " & config.enthusiastic
}

println("Module integration test passed!")
